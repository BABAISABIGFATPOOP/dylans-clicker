{
  "name": "dylans-clicker",
  "version": "1.2.1",
  "description": "Pollution Clicker - Desktop Edition",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.dylan.pollutionclicker",
    "productName": "DylansClicker",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "icon.ico",
      "icon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "BABAISABIGFATPOOP",
        "repo": "dylans-clicker"
      }
    ]
  }
}
